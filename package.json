{
  "name": "macro-helper",
  "displayName": "C Macro Helper",
  "description": "Extension for easier creation of multiline macros for C/C++",
  "version": "1.0.0",
  "publisher": "nikdor",
  "icon": "assets/extension-icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "c",
    "cpp",
    "c++",
    "macro",
    "multiline-macro",
    "preprocessor",
    "backslash",
    "alignment",
    "formatter",
    "cplusplus"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/duckysmacky/macro-helper.git"
  },
  "homepage": "https://github.com/duckysmacky/macro-helper",
  "activationEvents": [
    "onLanguage:c",
    "onLanguage:cpp"
  ],
  "main": "./extension.js",
  "scripts": {
    "vscode:prepublish": "npm run check && npm test",
    "check": "node --check extension.js && node --check src/formatter.js && node --check test/formatter.test.js",
    "test": "node --test"
  },
  "contributes": {
    "commands": [
      {
        "command": "macroHelper.alignMacroContinuations",
        "title": "Macro Helper: Add and Align Backslashes",
        "category": "Macro Helper"
      },
      {
        "command": "macroHelper.alignMacroDefinition",
        "title": "Macro Helper: Finalize Multiline Macro",
        "category": "Macro Helper"
      }
    ],
    "keybindings": [
      {
        "command": "macroHelper.alignMacroContinuations",
        "key": "ctrl+alt+\\",
        "mac": "cmd+alt+\\",
        "when": "editorTextFocus && !editorReadonly && (editorLangId == c || editorLangId == cpp)"
      },
      {
        "command": "macroHelper.alignMacroDefinition",
        "key": "ctrl+alt+shift+\\",
        "mac": "cmd+alt+shift+\\",
        "when": "editorTextFocus && !editorReadonly && (editorLangId == c || editorLangId == cpp)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "macroHelper.alignMacroContinuations",
          "when": "editorTextFocus && !editorReadonly && (resourceLangId == c || resourceLangId == cpp)",
          "group": "modification@10"
        },
        {
          "command": "macroHelper.alignMacroDefinition",
          "when": "editorTextFocus && !editorReadonly && (resourceLangId == c || resourceLangId == cpp)",
          "group": "modification@11"
        }
      ]
    },
    "configuration": {
      "title": "C Macro Helper",
      "properties": {
        "macroHelper.alignmentGap": {
          "type": "integer",
          "default": 8,
          "minimum": 1,
          "description": "How many spaces to leave between the longest macro line and the aligned backslash column."
        }
      }
    }
  }
}
